          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n    \"provider\": \"GOOGLE\",\n    \"idToken\": \"google_id_token_here\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/auth/social-login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "social-login"] }
          }
