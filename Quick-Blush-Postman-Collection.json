            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n    \"refreshToken\": \"your_refresh_token_here\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/auth/refresh-token", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "refresh-token"] }
          }
