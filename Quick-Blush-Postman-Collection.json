{
  "info": {
    "name": "Quick Blush - Live API Collection",
    "description": "Complete Postman collection for Quick Blush backend. Base URL: http://quickblush.in\n\nAfter calling /api/auth/verify-otp, copy the 'token' from the response and paste it into the JWT_TOKEN collection variable to authorize all protected endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://quickblush.in", "type": "string" },
    { "key": "JWT_TOKEN", "value": "paste_your_user_jwt_token_here", "type": "string" },
    { "key": "VENDOR_TOKEN", "value": "paste_your_vendor_jwt_token_here", "type": "string" },
    { "key": "ADMIN_TOKEN", "value": "paste_your_admin_jwt_token_here", "type": "string" },
    { "key": "BOOKING_ID", "value": "booking_uuid_here", "type": "string" },
    { "key": "VENDOR_ID", "value": "vendor_uuid_here", "type": "string" },
    { "key": "SERVICE_ID", "value": "service_id_here", "type": "string" },
    { "key": "CATEGORY_ID", "value": "category_id_here", "type": "string" },
    { "key": "ADDRESS_ID", "value": "address_uuid_here", "type": "string" }
  ],
  "item": [
    {
      "name": "🛠 System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/health", "host": ["{{BASE_URL}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n    \"mobile\": \"9999999990\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/auth/send-otp", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "send-otp"] }
          }
        },
        {
          "name": "Verify OTP (Login / Register)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n    \"mobile\": \"9999999990\",\n    \"otp\": \"123456\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/auth/verify-otp", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "verify-otp"] }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n    \"mobile\": \"9999999990\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/auth/resend-otp", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "resend-otp"] }
          }
        },
        {
          "name": "Complete Registration (After OTP)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{JWT_TOKEN}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane@example.com\",\n    \"password\": \"SecurePass123!\",\n    \"gender\": \"FEMALE\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/auth/register-details", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "register-details"] }
          }
        },
        {
          "name": "Login with Email & Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n    \"emailOrMobile\": \"jane@example.com\",\n    \"password\": \"SecurePass123!\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{JWT_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/auth/logout", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "logout"] }
